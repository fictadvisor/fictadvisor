{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": "./tests",
  "modulePaths": [
    "<rootDir>"
  ],
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "diagnostics": false
      }
    ]
  },
  "coverageDirectory": "coverage/unit",
  "coverageReporters": [
    "html"
  ],
  "testEnvironment": "node"
}
