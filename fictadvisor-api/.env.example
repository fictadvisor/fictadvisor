# S3-compatible object storage (MinIO).
# S3_ENDPOINT   — internal endpoint the API uses for data ops (e.g. http://minio:9000).
# S3_PUBLIC_URL — browser-reachable base for public avatar links + presigned URLs
#                 (e.g. https://storage.ficeadvisor.com). Falls back to S3_ENDPOINT if unset.
S3_ENDPOINT=
S3_PUBLIC_URL=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=

ADMISSION_EMAIL=

COMPLAINT_CHAT_ID=
