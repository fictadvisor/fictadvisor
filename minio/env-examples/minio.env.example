# Copy to ~/deployment/env/minio.env
#
# Root credentials for the shared MinIO instance (S3 API :9000, console :9001).
# One instance serves both prod and dev (it sits on both networks); keep the two
# environments apart with a separate bucket each. These values become the
# initial access key / secret key. Use a strong password for any non-local
# deploy, and prefer creating scoped access keys in the console over handing the
# root credentials to the app.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
