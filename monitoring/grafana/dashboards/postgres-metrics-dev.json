    {
      "type": "table",
      "title": "Top queries by execution time (pg_stat_statements)",
      "description": "Real application SQL from pg_stat_statements, captured every 5 min into pgss_snapshots and shown as per-range DELTAS over the dashboard time range ($__timeFrom/$__timeTo). IN-list variants are collapsed into one row. Granularity ~5 min, so ranges shorter than ~10 min may show nothing. total_ms / mean_ms are milliseconds.",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "pg-dev"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "mean_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "calls"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "rows"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "query"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "auto",
                  "wrapText": true
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        },
        "sortBy": [
          {
            "displayName": "mean_ms",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "pg-dev"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  regexp_replace(regexp_replace(q.query, 'IN \\(\\$\\d+(, ?\\$\\d+)*\\)', 'IN (...)', 'g'), '\\$\\d+', '$', 'g') AS query,\n  round((sum(p.d_total) / NULLIF(sum(p.d_calls), 0))::numeric, 2) AS mean_ms,\n  sum(p.d_calls) AS calls,\n  sum(p.d_rows) AS rows,\n  round(sum(p.d_total)::numeric, 1) AS total_ms\nFROM (\n  SELECT s.queryid,\n    GREATEST(max(s.total_exec_time) - min(s.total_exec_time), 0) AS d_total,\n    GREATEST(max(s.calls) - min(s.calls), 0) AS d_calls,\n    GREATEST(max(s.rows) - min(s.rows), 0) AS d_rows\n  FROM pgss_snapshots s\n  WHERE s.captured_at BETWEEN $__timeFrom() AND $__timeTo()\n  GROUP BY s.queryid\n) p\nJOIN pgss_query q USING (queryid)\nWHERE q.query LIKE '%\"public\".\"%'\n  AND p.d_calls > 0\nGROUP BY regexp_replace(regexp_replace(q.query, 'IN \\(\\$\\d+(, ?\\$\\d+)*\\)', 'IN (...)', 'g'), '\\$\\d+', '$', 'g')\nORDER BY mean_ms DESC NULLS LAST\nLIMIT 25"
        }
      ]
    }
  ]
}
