{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "title": "PostgreSQL \u2014 dev",
  "uid": "fictadvisor-postgres-dev",
  "tags": [
    "fictadvisor",
    "postgres",
    "dev"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "refresh": "10s",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "PostgreSQL up",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "pg_up{job=\"postgres-dev\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active backends",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(pg_stat_database_numbackends{job=\"postgres-dev\"})"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Cache hit ratio",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_blks_hit{job=\"postgres-dev\"}[5m])) / clamp_min(sum(rate(pg_stat_database_blks_hit{job=\"postgres-dev\"}[5m])) + sum(rate(pg_stat_database_blks_read{job=\"postgres-dev\"}[5m])), 1)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Deadlocks (5m)",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(pg_stat_database_deadlocks{job=\"postgres-dev\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backends per database",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "pg_stat_database_numbackends{job=\"postgres-dev\",datname!=\"\"}",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Commits vs rollbacks (per s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_xact_commit{job=\"postgres-dev\"}[5m]))",
          "legendFormat": "commits"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_xact_rollback{job=\"postgres-dev\"}[5m]))",
          "legendFormat": "rollbacks"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tuples fetched / returned (per s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_tup_fetched{job=\"postgres-dev\"}[5m]))",
          "legendFormat": "fetched"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_tup_returned{job=\"postgres-dev\"}[5m]))",
          "legendFormat": "returned"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rows inserted / updated / deleted (per s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_tup_inserted{job=\"postgres-dev\"}[5m]))",
          "legendFormat": "inserted"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_tup_updated{job=\"postgres-dev\"}[5m]))",
          "legendFormat": "updated"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_tup_deleted{job=\"postgres-dev\"}[5m]))",
          "legendFormat": "deleted"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "DB connections (vs max_connections)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(pg_stat_database_numbackends{job=\"postgres-dev\"})",
          "legendFormat": "total connections"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(pg_stat_activity_count{job=\"postgres-dev\"}) by (state)",
          "legendFormat": "{{state}}"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "pg_settings_max_connections{job=\"postgres-dev\"}",
          "legendFormat": "max connections"
        }
      ]
    }
  ]
}
