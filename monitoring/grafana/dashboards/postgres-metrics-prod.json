{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "title": "PostgreSQL \u2014 prod",
  "uid": "fictadvisor-postgres-prod",
  "tags": [
    "fictadvisor",
    "postgres",
    "prod"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "refresh": "10s",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "PostgreSQL up",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "pg_up{job=\"postgres\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active backends",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(pg_stat_database_numbackends{job=\"postgres\"})"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Cache hit ratio",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_blks_hit{job=\"postgres\"}[$__range])) / clamp_min(sum(rate(pg_stat_database_blks_hit{job=\"postgres\"}[$__range])) + sum(rate(pg_stat_database_blks_read{job=\"postgres\"}[$__range])), 1)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Deadlocks (range)",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(pg_stat_database_deadlocks{job=\"postgres\"}[$__range]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backends per database",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "pg_stat_database_numbackends{job=\"postgres\",datname!=\"\"}",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Commits vs rollbacks (per s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_xact_commit{job=\"postgres\"}[$__rate_interval]))",
          "legendFormat": "commits"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_xact_rollback{job=\"postgres\"}[$__rate_interval]))",
          "legendFormat": "rollbacks"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tuples fetched / returned (per s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_tup_fetched{job=\"postgres\"}[$__rate_interval]))",
          "legendFormat": "fetched"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_tup_returned{job=\"postgres\"}[$__rate_interval]))",
          "legendFormat": "returned"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rows inserted / updated / deleted (per s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_tup_inserted{job=\"postgres\"}[$__rate_interval]))",
          "legendFormat": "inserted"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_tup_updated{job=\"postgres\"}[$__rate_interval]))",
          "legendFormat": "updated"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(pg_stat_database_tup_deleted{job=\"postgres\"}[$__rate_interval]))",
          "legendFormat": "deleted"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "DB connections (vs max_connections)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(pg_stat_database_numbackends{job=\"postgres\"})",
          "legendFormat": "total connections"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(pg_stat_activity_count{job=\"postgres\"}) by (state)",
          "legendFormat": "{{state}}"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "pg_settings_max_connections{job=\"postgres\"}",
          "legendFormat": "max connections"
        }
      ]
    },
    {
      "type": "table",
      "title": "Top queries by execution time (pg_stat_statements)",
      "description": "Real application SQL statements from pg_stat_statements (monitoring/admin queries excluded), ordered by mean execution time. Cumulative since the last stats reset — pg_stat_statements has no per-time data, so this table is not filtered by the dashboard time range. total_ms / mean_ms are milliseconds.",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "pg-prod"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "mean_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "calls"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "rows"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "query"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "auto",
                  "wrapText": true
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        },
        "sortBy": [
          {
            "displayName": "mean_ms",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "pg-prod"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  regexp_replace(query, 'IN \\(\\$\\d+(, ?\\$\\d+)*\\)', 'IN (...)', 'g') AS query,\n  round(mean_exec_time::numeric, 2) AS mean_ms,\n  calls,\n  rows,\n  round(total_exec_time::numeric, 1) AS total_ms\nFROM pg_stat_statements\nWHERE dbid IN (SELECT oid FROM pg_database WHERE datname = current_database())\n  AND query LIKE '%\"public\".\"%'\nORDER BY mean_exec_time DESC\nLIMIT 25"
        }
      ]
    }
  ]
}
