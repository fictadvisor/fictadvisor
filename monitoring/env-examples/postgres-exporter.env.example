# Copy to ~/deployment/env/postgres-exporter.env
#
# Connection string for the PROD postgres-exporter -> postgres-db.
# The password must match POSTGRES_PASSWORD in ~/deployment/env/postgres.env.
# Host is the compose service name (postgres-db), port is the in-container 5432.
DATA_SOURCE_NAME=postgresql://postgres:CHANGE_ME@postgres-db:5432/postgres?sslmode=disable
